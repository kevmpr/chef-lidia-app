---
import { actions } from 'astro:actions';
import '../../styles/global.css';

const { session, supabase } = Astro.locals;
if (!session) {
  return Astro.redirect('/login');
}

// Obtener platos con su categoría unida
const { data: dishes, error } = await supabase
  .from('dishes')
  .select('*, category:categories(name)')
  .order('created_at', { ascending: false });

---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Platos - Chef Lidia</title>
  </head>
  <body class="bg-amber-50 min-h-screen font-sans text-gray-800 pb-24">
    <header class="bg-white shadow-sm p-4 flex items-center justify-between sticky top-0 z-20">
      <div class="flex items-center gap-3">
        <h1 class="text-xl font-serif font-bold text-olive-800">Tus Platos</h1>
      </div>
      <a 
        href="/platos/nuevo" 
        class="bg-olive-600 hover:bg-olive-700 text-white font-medium px-4 py-2 rounded-xl transition-colors text-sm shadow-sm"
      >
        + Crear Plato
      </a>
    </header>

    <main class="p-4 max-w-2xl mx-auto space-y-6">
      
      {error && (
        <p class="text-red-500 bg-red-50 p-4 rounded-xl">Error cargando platos: {error.message}</p>
      )}

      {dishes && dishes.length === 0 && (
        <div class="bg-white text-olive-600 p-8 rounded-2xl text-center border border-olive-100 shadow-sm flex flex-col items-center">
          <span class="text-4xl mb-3">🍽️</span>
          <p class="font-medium">Tu menú está vacío</p>
          <p class="text-sm opacity-80 mt-1">Agrega tus mejores recetas para comenzar.</p>
        </div>
      )}

      <!-- Grilla de platos (2 columnas en móviles, 3 en tablets) -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {dishes?.map((dish) => (
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden flex flex-col group relative">
            
            <!-- Etiqueta Menú del día vs Fijo -->
            <div class="absolute top-2 left-2 z-10">
              {dish.is_fixed ? (
                <span class="bg-gray-800/80 backdrop-blur-sm text-white text-[10px] uppercase tracking-wider font-bold px-2 py-1 rounded-md">Carta Fija</span>
              ) : (
                <span class="bg-olive-600/90 text-white text-[10px] uppercase tracking-wider font-bold px-2 py-1 rounded-md shadow-sm">Menú del Día</span>
              )}
            </div>

            <!-- Botón Eliminar -->
            <form method="POST" action={actions.deleteDish} class="absolute top-2 right-2 z-10">
              <input type="hidden" name="id" value={dish.id} />
              <button 
                type="submit" 
                class="bg-white/80 backdrop-blur-sm hover:bg-red-50 text-red-500 rounded-full p-1.5 shadow-sm transition-colors"
                aria-label="Eliminar plato"
                onclick="return confirm('¿Seguro que deseas eliminar este plato?');"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
              </button>
            </form>

            <div class="aspect-square bg-gray-100 relative">
              {dish.image_url ? (
                <img src={dish.image_url} alt={dish.name} class="w-full h-full object-cover" loading="lazy" />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-gray-300">
                  <span class="text-3xl">🍲</span>
                </div>
              )}
            </div>
            
            <div class="p-3 flex-1 flex flex-col">
              <p class="text-xs text-olive-600 font-medium truncate mb-0.5">
                {dish.category?.name || 'Sin Categoría'}
              </p>
              <h3 class="font-bold text-gray-900 leading-tight mb-1 line-clamp-2">{dish.name}</h3>
              
              <div class="mt-auto pt-2 flex justify-between items-center">
                <span class="font-medium text-olive-800 bg-amber-100/50 px-2 py-0.5 rounded text-sm">${dish.price}</span>
              </div>
            </div>
          </div>
        ))}
      </div>

    </main>

    <!-- Barra de Navegación Inferior -->
    <footer class="fixed bottom-0 w-full bg-white border-t border-gray-200 flex justify-around p-3 text-xs text-gray-400 font-medium pb-safe z-30">
      <a href="/" class="flex flex-col items-center hover:text-olive-700">
        <span class="text-xl mb-1">🏠</span>
        Inicio
      </a>
      <a href="/categorias" class="flex flex-col items-center hover:text-olive-700">
        <span class="text-xl mb-1">🏷️</span>
        Categorías
      </a>
      <a href="/platos" class="flex flex-col items-center text-olive-700 pointer-events-none">
        <span class="text-xl mb-1">🥘</span>
        Platos
      </a>
    </footer>
  </body>
</html>
