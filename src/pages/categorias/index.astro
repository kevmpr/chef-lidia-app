---
import { actions } from 'astro:actions';
import Layout from '../../layouts/Layout.astro';

const { session, supabase } = Astro.locals;
if (!session) {
  return Astro.redirect('/login');
}

// Obtener categorías del usuario actual
const { data: categories, error } = await supabase
  .from('categories')
  .select('*')
  .order('created_at', { ascending: false });

// El resultado de una action (si hubo submit previo en esta carga)
const result = Astro.getActionResult(actions.createCategory);
---

<Layout title="Categorías - Chef Lidia" bodyClass="bg-amber-50 min-h-screen font-sans text-gray-800 pb-20">
    <header class="bg-white shadow-sm p-4 flex items-center justify-between sticky top-0 z-10">
      <div class="flex items-center gap-3">
        <a href="/" class="text-olive-700 font-bold text-xl">←</a>
        <h1 class="text-xl font-serif font-bold text-olive-800">Categorías</h1>
      </div>
    </header>

    <main class="p-4 max-w-lg mx-auto mt-2 space-y-6">
      
      <!-- Formulario para Nueva Categoría -->
      <section class="bg-white p-5 rounded-2xl shadow-sm border border-gray-100">
        <h2 class="font-bold mb-3 text-olive-800">Nueva Categoría</h2>
        
        <form method="POST" action={actions.createCategory} class="flex gap-2">
          <input 
            type="text" 
            name="name" 
            placeholder="Ej: Entradas, Postres..." 
            required
            class="flex-1 bg-gray-50 border border-gray-200 rounded-xl px-4 py-2 focus:outline-none focus:ring-2 focus:ring-olive-500"
          />
          <button 
            type="submit" 
            class="bg-olive-600 hover:bg-olive-700 text-white font-medium px-5 py-2 rounded-xl transition-colors"
          >
            Agregar
          </button>
        </form>

        {result && result.error && (
          <p class="text-red-500 text-sm mt-2">{result.error.message}</p>
        )}
      </section>

      <!-- Lista de Categorías -->
      <section class="space-y-3">
        <h2 class="font-bold text-gray-700 ml-1">Tus Categorías</h2>
        
        {error && <p class="text-red-500">Error cargando: {error.message}</p>}
        
        {categories && categories.length === 0 && (
          <div class="bg-olive-50 text-olive-600 p-4 rounded-xl text-center text-sm border border-olive-100">
            Aún no tienes categorías. ¡Crea la primera arriba!
          </div>
        )}

        <div class="space-y-2">
          {categories?.map((cat) => (
            <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100 flex justify-between items-center group">
              <span class="font-medium">{cat.name}</span>
              <form method="POST" action={actions.deleteCategory}>
                <input type="hidden" name="id" value={cat.id} />
                <button 
                  type="submit" 
                  class="text-red-400 hover:text-red-600 p-2 opacity-80 group-hover:opacity-100 transition-opacity"
                  aria-label="Eliminar"
                  onclick="return confirm('¿Seguro que deseas eliminar esta categoría?');"
                >
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                </button>
              </form>
            </div>
          ))}
        </div>
      </section>

    </main>

    <!-- Barra de Navegación Inferior -->
    <footer class="fixed bottom-0 w-full bg-white border-t border-gray-200 flex justify-around p-3 text-xs text-gray-400 font-medium pb-safe z-10">
      <a href="/" class="flex flex-col items-center hover:text-olive-700">
        <span class="text-xl mb-1">🏠</span>
        Inicio
      </a>
      <a href="/categorias" class="flex flex-col items-center text-olive-700 pointer-events-none">
        <span class="text-xl mb-1">🏷️</span>
        Categorías
      </a>
      <a href="/platos" class="flex flex-col items-center hover:text-olive-700">
        <span class="text-xl mb-1">🥘</span>
        Platos
      </a>
    </footer>
</Layout>
